# Google OAuth — from https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Base URL of this app (no trailing slash)
APP_URL=

# MongoDB — mongodb+srv://... for Atlas, or mongodb://localhost:27017/reversim-backoffice for local
MONGODB_URI=
